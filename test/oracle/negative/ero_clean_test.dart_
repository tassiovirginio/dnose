  test('uses completes matcher', () {
    expect(Future.value('done'), completes);
  });

  // CLEAN: Proper Stream handling with expectLater
  test('handles stream with expectLater', () {
    final stream = Stream.fromIterable([1, 2, 3]);
    expectLater(stream, emitsInOrder([1, 2, 3]));
