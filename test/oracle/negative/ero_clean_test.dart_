  test('awaits async operation correctly', () async {
    final result = await Future.value(42);
    expect(result, equals(42));
  });

  // CLEAN: Using expectLater for Future
  test('uses expectLater for async assertion', () {
    expectLater(Future.value(10), completion(equals(10)));
  });

