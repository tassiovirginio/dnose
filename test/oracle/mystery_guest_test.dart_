/// Oracle: Mystery Guest - Expanded version matching detector pattern
/// The detector specifically looks for File('path').readAsStringSync() pattern
/// Expected detections: 6

import 'dart:convert';
import 'dart:io';
import 'package:test/test.dart';

class Gift {
  final int id;
  final String name;
  Gift({required this.id, required this.name});
  factory Gift.fromJson(Map<String, dynamic> json) {
    return Gift(id: json['id'], name: json['name']);
  }
}

void main() {
  // SMELL 1: File('path').readAsStringSync() - JSON config
  test('reads JSON from file', () {
    final file = File('config/settings.json').readAsStringSync();
    final data = jsonDecode(file);
    expect(data, isNotNull);
  });

  // SMELL 2: File('path').readAsStringSync() - Gift model
  test('Gift model test', () {
    final file = File('json/gift_test.json').readAsStringSync();
    final gifts = Gift.fromJson(jsonDecode(file) as Map<String, dynamic>);
    expect(gifts.id, 999);
  });

  // SMELL 3: File('path').readAsStringSync() - User data
  test('loads user data', () {
    final content = File('data/users.json').readAsStringSync();
    final users = jsonDecode(content);
    expect(users, isNotEmpty);
  });

  // SMELL 4: File('path').readAsStringSync() - Template
  test('reads template file', () {
    final template = File('templates/email.html').readAsStringSync();
    expect(template.contains('<html>'), isTrue);
  });

  // SMELL 5: File('path').readAsStringSync() - Environment config
  test('reads env config', () {
    final env = File('.env').readAsStringSync();
    expect(env.isNotEmpty, isTrue);
  });

  // SMELL 6: File('path').readAsStringSync() - Test fixtures
  test('loads test fixtures', () {
    final fixtures = File('test/fixtures/data.json').readAsStringSync();
    final data = jsonDecode(fixtures);
    expect(data['name'], equals('test'));
  });

  // ============================================
  // NOT A SMELL: Using inline string data
  // ============================================
  
  test('uses inline JSON data', () {
    final jsonString = '{"id": 1, "name": "Test"}';
    final data = jsonDecode(jsonString);
    expect(data['id'], equals(1));
  });

  // NOT A SMELL: Variable file path (not string literal)
  test('uses variable file path', () {
    final path = 'data.json';
    // This pattern is not detected because path is not a string literal
    expect(path.isNotEmpty, isTrue);
  });

  // NOT A SMELL: Using File() without readAsStringSync
  test('checks file existence', () {
    final exists = true; // File('test.txt').existsSync() - different method
    expect(exists, isTrue);
  });
}
